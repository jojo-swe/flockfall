; Flockfall - Godot 4 prototype
; Open this folder in Godot 4.3 or newer.

config_version=5

[application]
config/name="Flockfall"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")

[display]
window/size/viewport_width=720
window/size/viewport_height=1280
window/size/window_width_override=540
window/size/window_height_override=960
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/use_nearest_mipmap_filter=false

audio/default_bus_layout="res://default_bus_layout.tres"

[layer_names]
2d_physics/layer_1="Bird"
2d_physics/layer_2="Peg"
